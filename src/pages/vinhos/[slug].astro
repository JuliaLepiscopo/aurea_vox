---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Reveal from '~/components/Reveal.astro';
import Button from '~/components/Button.astro';
import SensoryRadar from '~/components/islands/SensoryRadar.astro';
import { wines } from '~/data/wines';
import { vineyards } from '~/data/vineyards';
import { dishes } from '~/data/pairings';

export function getStaticPaths() {
  return wines.map((w) => ({ params: { slug: w.slug }, props: { wine: w } }));
}

const { wine } = Astro.props;
const vineyard = vineyards.find((v) => v.id === wine.vineyardId);
const pairings = dishes.filter((d) => d.matches.includes(wine.slug));
const related = wines.filter((w) => w.slug !== wine.slug && w.type === wine.type).slice(0, 3);
---

<BaseLayout current="vinhos" title={`${wine.name} ${wine.vintage} · Aurea Vox`}>
  <!-- Hero garrafa -->
  <section class="relative pt-24 sm:pt-28 md:pt-32 pb-14 md:pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/vinho6.png" alt="" class="w-full h-full object-cover opacity-30 blur-xl scale-110" data-parallax="0.1"/>
      <div class="absolute inset-0 bg-gradient-to-b from-nero-profundo via-nero-profundo/80 to-nero-profundo"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-5 sm:px-6 lg:px-10 grid lg:grid-cols-[1fr_1.3fr] gap-10 md:gap-14 lg:gap-16 items-center">
      <Reveal direction="left">
        <div class="relative max-w-md mx-auto">
          <div class="relative aspect-[3/4] floaty grid place-items-center">
            <img src="/vinho6.png" alt={wine.name} class="max-h-full w-auto object-contain drop-shadow-[0_30px_60px_rgba(0,0,0,0.7)]"/>
          </div>
          {wine.limitedEdition && (
            <div class="-mt-14 md:-mt-16 flex justify-end pr-0 relative z-10">
              <span class="text-[0.58rem] tracking-label uppercase text-gold bg-black py-2 px-4 border border-[var(--line-strong)]">Edição Limitada</span>
            </div>
          )}
        </div>
      </Reveal>

      <Reveal direction="right" delay={120}>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-creme leading-[1.0] md:leading-[0.95]">{wine.name}</h1>
        <div class="mt-3 font-display text-6xl sm:text-7xl md:text-8xl text-gold-gradient">{wine.vintage}</div>

        <p class="mt-6 md:mt-8 text-creme/75 leading-relaxed text-[0.95rem] md:text-lg max-w-xl">{wine.tasting.palate}</p>

        <dl class="mt-8 md:mt-10 grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6 text-sm">
          <div>
            <dt class="text-[0.6rem] tracking-label uppercase text-creme/50">Castas</dt>
            <dd class="mt-1 text-creme">{wine.grapes.join(' · ')}</dd>
          </div>
          <div>
            <dt class="text-[0.6rem] tracking-label uppercase text-creme/50">Álcool</dt>
            <dd class="mt-1 font-display text-2xl text-creme">{wine.alcohol}%</dd>
          </div>
          <div>
            <dt class="text-[0.6rem] tracking-label uppercase text-creme/50">Envelhecimento</dt>
            <dd class="mt-1 text-creme/80">{wine.aging}</dd>
          </div>
          {wine.score && (
            <div>
              <dt class="text-[0.6rem] tracking-label uppercase text-creme/50">Pontuação</dt>
              <dd class="mt-1 font-display text-2xl text-gold-gradient">{wine.score}/100</dd>
            </div>
          )}
        </dl>

        <div class="mt-8 md:mt-10 pt-6 md:pt-8 border-t border-dourado/20 flex items-center justify-between flex-wrap gap-5">
          <div>
            <div class="text-[0.62rem] md:text-[0.65rem] tracking-label uppercase text-creme/50">Valor da garrafa</div>
            <div class="mt-1 font-display text-3xl sm:text-4xl text-gold-gradient">R$ {wine.price.toLocaleString('pt-BR')}</div>
          </div>
          <div class="flex items-center gap-3 flex-wrap">
            <Button variant="primary">Reservar Garrafa</Button>
            <Button variant="ghost" icon="none">Adicionar à Adega</Button>
          </div>
        </div>

        {wine.allocation && (
          <p class="mt-6 text-xs tracking-luxury text-dourado-quente">Alocação mundial · {wine.allocation} garrafas</p>
        )}
      </Reveal>
    </div>
  </section>

  <!-- Perfil sensorial + notas -->
  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-10 py-16 md:py-24">
    <div class="grid lg:grid-cols-[1fr_1fr] gap-12 md:gap-16 items-center">
      <Reveal>
        <div class="w-full max-w-[520px] mx-auto">
          <SensoryRadar sensory={wine.sensory} size={520}/>
        </div>
      </Reveal>

      <Reveal delay={120}>
        <h2 class="font-display font-light text-4xl md:text-5xl lg:text-[3.2rem] text-pearl leading-[1.05] tracking-[-0.015em]">
          Perfil <em class="text-gold not-italic">sensorial</em>.
        </h2>

        {vineyard && (
          <div class="mt-12 relative px-8 py-8 md:px-10 md:py-10">
            <span class="absolute top-0 left-0 w-6 h-6 border-t border-l border-gold"></span>
            <span class="absolute top-0 right-0 w-6 h-6 border-t border-r border-gold"></span>
            <span class="absolute bottom-0 left-0 w-6 h-6 border-b border-l border-gold"></span>
            <span class="absolute bottom-0 right-0 w-6 h-6 border-b border-r border-gold"></span>

            <div class="flex items-baseline justify-between gap-4">
              <span class="text-[0.58rem] tracking-[0.3em] uppercase text-gold">Origem</span>
              <span class="text-[0.55rem] tracking-[0.22em] uppercase text-pearl/45">Parcela única</span>
            </div>
            <h3 class="mt-4 font-display font-light text-[2rem] md:text-[2.2rem] text-pearl leading-none tracking-[-0.01em]">{vineyard.name}</h3>
            <p class="mt-5 text-sm text-pearl/65 leading-[1.8] max-w-md">{vineyard.description}</p>
            <div class="mt-6 pt-5 border-t border-[var(--line)] grid grid-cols-2 gap-4">
              <div>
                <div class="text-[0.55rem] tracking-[0.28em] uppercase text-pearl/45">Altitude</div>
                <div class="mt-2 font-display font-light text-[1.2rem] text-gold">{vineyard.altitude}</div>
              </div>
              <div>
                <div class="text-[0.55rem] tracking-[0.28em] uppercase text-pearl/45">Solo</div>
                <div class="mt-2 font-display font-light text-[1.2rem] text-gold">{vineyard.soil[0]}</div>
              </div>
            </div>
          </div>
        )}
      </Reveal>
    </div>
  </section>

  <!-- Harmonizações -->
  {pairings.length > 0 && (
    <section class="relative py-24 border-t border-dourado/10 bg-antracite/30">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <Reveal>
          <span class="label-luxury">Harmonização</span>
          <h2 class="mt-4 font-display text-4xl md:text-5xl text-creme">Harmoniza com a <em class="text-gold-gradient not-italic">arte</em> da mesa.</h2>
        </Reveal>

        <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {pairings.map((d, i) => (
            <Reveal delay={i * 100}>
              <article data-tilt class="tilt p-7 bg-gunmetal/60 border border-dourado/15 h-full rounded-2xl">
                <span class="text-[0.6rem] tracking-label uppercase text-dourado-quente">{d.category}</span>
                <h3 class="mt-3 font-display text-2xl text-creme">{d.name}</h3>
                <div class="divider-gold mt-4"></div>
                <p class="mt-4 text-sm text-creme/70 leading-relaxed">{d.description}</p>
              </article>
            </Reveal>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Relacionados -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 py-24">
    <Reveal>
      <div class="flex items-end justify-between gap-4 flex-wrap">
        <h2 class="font-display text-4xl text-creme">Da mesma <em class="text-gold-gradient not-italic">família</em></h2>
        <Button href="/vinhos" variant="link">Ver coleção completa</Button>
      </div>
    </Reveal>

    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {related.map((r, i) => {
        const relatedImages = ['/vinho7.jpeg', '/vinho8.jpeg', '/vinho9.jpeg'];
        return (
        <Reveal delay={i * 100}>
          <a href={`/vinhos/${r.slug}`} data-tilt class="tilt shimmer group relative block overflow-hidden bg-gunmetal/60 border border-dourado/10 hover:border-dourado-quente/40 h-[420px] transition-colors duration-700 rounded-2xl">
            <img src={relatedImages[i % relatedImages.length]} class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:opacity-95 group-hover:scale-105 transition-all duration-[1400ms]" alt=""/>
            <div class="absolute inset-0 bg-gradient-to-t from-nero-profundo to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-6">
              <span class="text-[0.6rem] tracking-label uppercase text-dourado-quente">{r.collection}</span>
              <div class="mt-2 font-display text-4xl text-gold-gradient">{r.vintage}</div>
              <div class="font-display text-xl text-creme">{r.name}</div>
            </div>
          </a>
        </Reveal>
        );
      })}
    </div>
  </section>
</BaseLayout>
