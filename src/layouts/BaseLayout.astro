---
import '~/styles/global.css';
import Navbar from '~/components/Navbar.astro';
import MobileNav from '~/components/MobileNav.astro';
import Footer from '~/components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  current?: 'home' | 'terroir' | 'vinhos' | 'clube' | 'shop';
}

const {
  title = 'Aurea Vox · A Voz Dourada',
  description = 'Vinhos artesanais de exceção. Terroir milenar, vindima reservada, edições limitadas para os mais refinados conhecedores.',
  current,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ViewTransitions />
  </head>
  <body>
    <div class="progress-bar"></div>
    <Navbar current={current} />
    <MobileNav />

    <main>
      <slot />
    </main>

    <Footer />

    <script>
      import {
        initReveal,
        initProgressBar,
        initParallax,
        initCounters,
        initMagnetic,
        initSplitText,
      } from '~/scripts/reveal';

      const boot = () => {
        initReveal();
        initProgressBar();
        initParallax();
        initCounters();
        initMagnetic();
        initSplitText();
      };

      boot();
      document.addEventListener('astro:after-swap', boot);
    </script>
  </body>
</html>
