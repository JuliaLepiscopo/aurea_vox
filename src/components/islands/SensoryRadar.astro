---
import type { SensoryProfile } from '~/data/wines';

interface Props {
  sensory: SensoryProfile;
  size?: number;
}

const { sensory, size = 320 } = Astro.props;
const id = `radar-${Math.random().toString(36).slice(2, 8)}`;

const axes = [
  { key: 'body', label: 'Corpo' },
  { key: 'tannins', label: 'Taninos' },
  { key: 'acidity', label: 'Acidez' },
  { key: 'sweetness', label: 'Doçura' },
  { key: 'finish', label: 'Final' },
] as const;

const cx = size / 2;
const cy = size / 2;
const r = size * 0.38;
const steps = 5;

function pointAt(index: number, value: number) {
  const angle = (Math.PI * 2 * index) / axes.length - Math.PI / 2;
  const radius = (value / steps) * r;
  return { x: cx + Math.cos(angle) * radius, y: cy + Math.sin(angle) * radius };
}

const gridRings = Array.from({ length: steps }, (_, i) => {
  const rr = ((i + 1) / steps) * r;
  const pts = axes.map((_, j) => {
    const angle = (Math.PI * 2 * j) / axes.length - Math.PI / 2;
    return `${cx + Math.cos(angle) * rr},${cy + Math.sin(angle) * rr}`;
  });
  return pts.join(' ');
});

const axisLines = axes.map((_, i) => pointAt(i, steps));

const valuePoints = axes.map((a, i) => pointAt(i, sensory[a.key])).map((p) => `${p.x},${p.y}`).join(' ');
---

<div class="relative" data-radar-id={id}>
  <svg viewBox={`0 0 ${size} ${size}`} class="block mx-auto w-full h-auto" style={`max-width:${size}px;`}>
    <defs>
      <linearGradient id={`${id}-grad`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#e9c176" stop-opacity="0.6"/>
        <stop offset="1" stop-color="#d4af37" stop-opacity="0.25"/>
      </linearGradient>
    </defs>

    {gridRings.map((pts, i) => (
      <polygon points={pts} fill="none" stroke="#d4af37" stroke-width="0.5" opacity={0.15 + i * 0.05}/>
    ))}

    {axisLines.map((p) => (
      <line x1={cx} y1={cy} x2={p.x} y2={p.y} stroke="#d4af37" stroke-width="0.5" opacity="0.2"/>
    ))}

    <polygon
      points={valuePoints}
      fill={`url(#${id}-grad)`}
      stroke="#e9c176"
      stroke-width="1.5"
      class="radar-shape"
      style="opacity: 0; transform: scale(0.3); transform-origin: center;"
    />

    {axes.map((a, i) => {
      const p = pointAt(i, sensory[a.key]);
      return <circle cx={p.x} cy={p.y} r="3.5" fill="#e9c176" class="radar-dot" style="opacity: 0;"/>;
    })}

    {axes.map((a, i) => {
      const labelP = pointAt(i, steps + 0.8);
      return (
        <g>
          <text
            x={labelP.x}
            y={labelP.y}
            text-anchor="middle"
            dominant-baseline="middle"
            font-family="'Manrope', sans-serif"
            font-size="10"
            fill="#e9c176"
            letter-spacing="2"
          >{a.label.toUpperCase()}</text>
          <text
            x={labelP.x}
            y={labelP.y + 14}
            text-anchor="middle"
            font-family="'Cormorant Garamond', serif"
            font-size="14"
            fill="#e8dcc4"
          >{sensory[a.key]}/5</text>
        </g>
      );
    })}
  </svg>
</div>

<script define:vars={{ id }}>
  const root = document.querySelector(`[data-radar-id="${id}"]`);
  if (root) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const shape = root.querySelector('.radar-shape');
        const dots = root.querySelectorAll('.radar-dot');
        if (shape) {
          shape.animate(
            [
              { opacity: 0, transform: 'scale(0.3)' },
              { opacity: 1, transform: 'scale(1)' },
            ],
            { duration: 1200, easing: 'cubic-bezier(.22,1,.36,1)', fill: 'forwards' }
          );
        }
        dots.forEach((d, i) => {
          d.animate(
            [{ opacity: 0 }, { opacity: 1 }],
            { duration: 600, delay: 400 + i * 120, easing: 'ease-out', fill: 'forwards' }
          );
        });
        io.unobserve(root);
      });
    }, { threshold: 0.3 });
    io.observe(root);
  }
</script>
