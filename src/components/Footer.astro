---
const year = new Date().getFullYear();

const cols = [
  {
    title: 'Casa',
    links: [
      { label: 'Manifesto', href: '/terroir#manifesto' },
      { label: 'Terroir', href: '/terroir' },
      { label: 'Vindimas', href: '/terroir#timeline' },
    ],
  },
  {
    title: 'Coleção',
    links: [
      { label: 'Ícones', href: '/vinhos?collection=Ícone' },
      { label: 'Reserva', href: '/vinhos?collection=Reserva' },
      { label: 'Edições Limitadas', href: '/vinhos?collection=Edição Limitada' },
    ],
  },
  {
    title: 'Experiência',
    links: [
      { label: 'Clube Aurea', href: '/clube' },
      { label: 'Visitas à Adega', href: '/clube#visitas' },
      { label: 'Sommelier Privado', href: '/clube#sommelier' },
    ],
  },
];
---

<footer class="relative mt-8 md:mt-12 lg:mt-16 border-t border-[var(--line)]">
  <div class="relative max-w-7xl mx-auto px-5 sm:px-6 lg:px-10 pt-16 md:pt-20 lg:pt-24 pb-10">
    <!-- Linha editorial topo -->
    <div class="grid lg:grid-cols-[1.3fr_2.7fr] gap-12 md:gap-16 lg:gap-24">
      <div>
        <span class="font-display text-2xl sm:text-3xl tracking-[-0.01em] text-pearl">Aurea Vox</span>
        <p class="mt-5 md:mt-6 text-[0.85rem] md:text-sm leading-relaxed text-[var(--pearl-muted)] max-w-xs">
          Vinhos artesanais produzidos em parcelas milenares, destinados a conhecedores exigentes.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
        {cols.map((col) => (
          <div>
            <span class="label-luxury">{col.title}</span>
            <ul class="mt-5 flex flex-col gap-3">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-pearl/75 hover:text-gold transition-colors duration-500">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <div>
          <span class="label-luxury">Newsletter</span>
          <p class="mt-5 text-sm text-[var(--pearl-muted)]">Notas de safra e convites privados.</p>
          <form class="mt-5 flex flex-col gap-4" onsubmit="event.preventDefault(); this.querySelector('button').innerText='Convite enviado';">
            <input
              type="email"
              required
              placeholder="email privado"
              class="bg-transparent outline-none py-2 text-sm placeholder:text-pearl/30 text-pearl"
              style="border: none; border-bottom: 1px solid var(--line-strong);"
            />
            <button class="btn-ghost justify-center !py-2.5 !text-[0.66rem]">
              <span>Assinar</span>
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 md:mt-20 pt-6 md:pt-8 border-t border-[var(--line)] flex flex-col md:flex-row items-start md:items-center justify-between gap-5 md:gap-6">
      <p class="text-[0.68rem] md:text-xs tracking-luxury text-pearl/40">© {year} Aurea Vox · Todos os direitos reservados</p>

      <div class="flex items-center gap-6 md:gap-8">
        <a href="#" aria-label="Instagram" class="text-pearl/50 hover:text-gold transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
            <rect x="3" y="3" width="18" height="18" rx="4"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
        </a>
        <a href="#" aria-label="Facebook" class="text-pearl/50 hover:text-gold transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#" aria-label="Twitter" class="text-pearl/50 hover:text-gold transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.3 3h3.4l-7.4 8.5L22 21h-6.8l-5.3-6.9L3.8 21H.4l7.9-9L0 3h7l4.8 6.3L17.3 3z"/>
          </svg>
        </a>
      </div>

      <div class="flex items-center gap-4 sm:gap-6 text-[0.68rem] md:text-xs text-pearl/40 flex-wrap">
        <a href="#" class="hover:text-gold transition-colors">Privacidade</a>
        <a href="#" class="hover:text-gold transition-colors">Termos</a>
        <a href="#" class="hover:text-gold transition-colors">Beba com Moderação</a>
      </div>
    </div>

    <!-- Voltar ao topo — discreto, canto -->
    <a
      href="#"
      aria-label="Voltar ao topo"
      onclick="event.preventDefault(); window.scrollTo({top:0,behavior:'smooth'});"
      class="hidden sm:inline-flex absolute right-6 lg:right-10 top-8 md:top-10 group items-center gap-2 text-[0.65rem] tracking-label uppercase text-pearl/50 hover:text-gold transition-colors"
    >
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform duration-500 group-hover:-translate-y-0.5">
        <path d="M12 19V5M5 12l7-7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Topo</span>
    </a>
  </div>
</footer>
